    "@venture-forest/forest-engine": "workspace:*",
    "@venture-forest/layout-engine": "workspace:*",
    "@venture-forest/shared-types": "workspace:*",
    "framer-motion": "^11.15.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.468.0",
    "postprocessing": "^6.38.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.49",
